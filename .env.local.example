# 访问密码（部署到公网时必须设置）
# 不设置此项时，应用不需要密码即可访问（适合本地开发）
ACCESS_PASSWORD=your_password_here

# 是否信任反向代理转发的客户端 IP（X-Forwarded-For）。
# 默认不启用，避免公网请求伪造转发头绕过登录限流。
# 只有当 LumiMuse 部署在你控制的反向代理后面，且代理会覆盖客户端传入的转发头时才设为 1。
TRUST_PROXY=0

# 认证 token 签名密钥（可选，强烈建议设置）
# 用于对登录后下发的 cookie 进行 HMAC-SHA256 签名。
# 不设置时会从 ACCESS_PASSWORD 派生密钥作为兜底，安全性较弱：
# 一旦修改 ACCESS_PASSWORD 会导致所有已登录会话立即失效。
# 推荐使用至少 32 字节的随机字符串，例如：
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
