# 统一换行符为 LF，防止 Windows CRLF 混入导致编码混乱
* text=auto eol=lf

# 明确声明文本文件
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.css  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.mjs  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.env* text eol=lf

# 二进制文件不做处理
*.png  binary
*.jpg  binary
*.jpeg binary
*.webp binary
*.gif  binary
*.ico  binary
*.db   binary
*.db-shm binary
*.db-wal binary
